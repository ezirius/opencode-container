ARG UBUNTU_VERSION
ARG OPENCODE_HOST_UID
ARG OPENCODE_HOST_GID
ARG OPENCODE_CONTAINER_WORKSPACE_DIR
FROM ubuntu:${UBUNTU_VERSION}

ARG OPENCODE_HOST_UID
ARG OPENCODE_HOST_GID
ARG OPENCODE_CONTAINER_WORKSPACE_DIR

ARG OPENCODE_WRAPPER_LANE
ARG OPENCODE_WRAPPER_UPSTREAM
ARG OPENCODE_WRAPPER_UPSTREAM_REF
ARG OPENCODE_WRAPPER_CONTEXT
ARG OPENCODE_WRAPPER_COMMITSTAMP

ARG OPENCODE_RELEASE_ARCHIVE_URL
ARG OPENCODE_RELEASE_ARCHIVE_SHA512

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

LABEL opencode.wrapper.lane="${OPENCODE_WRAPPER_LANE}"
LABEL opencode.wrapper.upstream="${OPENCODE_WRAPPER_UPSTREAM}"
LABEL opencode.wrapper.upstream_ref="${OPENCODE_WRAPPER_UPSTREAM_REF}"
LABEL opencode.wrapper.context="${OPENCODE_WRAPPER_CONTEXT}"
LABEL opencode.wrapper.commitstamp="${OPENCODE_WRAPPER_COMMITSTAMP}"

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    tar \
    tini \
  && rm -rf /var/lib/apt/lists/* \
  && groupadd -o -g "$OPENCODE_HOST_GID" opencode \
  && useradd -o -m -u "$OPENCODE_HOST_UID" -g "$OPENCODE_HOST_GID" -d "/home/opencode" -s /bin/bash opencode \
  && mkdir -p "${OPENCODE_CONTAINER_WORKSPACE_DIR}" "/home/opencode" \
  && chown -R opencode:opencode /workspace "/home/opencode"

RUN test -n "$OPENCODE_RELEASE_ARCHIVE_URL" && test -n "$OPENCODE_RELEASE_ARCHIVE_SHA512" \
  && tmpdir="$(mktemp -d)" \
  && curl -fsSL "$OPENCODE_RELEASE_ARCHIVE_URL" -o "$tmpdir/opencode.tgz" \
  && printf '%s  %s\n' "$OPENCODE_RELEASE_ARCHIVE_SHA512" "$tmpdir/opencode.tgz" | sha512sum -c - \
  && tar -xzf "$tmpdir/opencode.tgz" -C "$tmpdir" \
  && install -m 755 "$tmpdir/package/bin/opencode" /usr/local/bin/opencode \
  && rm -rf "$tmpdir"

COPY config/containers/entrypoint.sh /usr/local/bin/opencode-wrapper-entrypoint
RUN chmod 755 /usr/local/bin/opencode-wrapper-entrypoint

USER opencode
WORKDIR ${OPENCODE_CONTAINER_WORKSPACE_DIR}

ENV HOME=/home/opencode

ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/opencode-wrapper-entrypoint"]
CMD ["sleep", "infinity"]
