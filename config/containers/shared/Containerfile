FROM ghcr.io/anomalyco/opencode:1.14.24

# This wrapper keeps a stable home path for the workspace-mounted OpenCode state.
ENV HOME=/root

# These wrapper additions keep git and the documented interactive shells available.
RUN apk add --no-cache git bash nushell

# This wrapper keeps the stable project-facing working directory expected by the scripts.
WORKDIR /workspace/project

# This wrapper keeps the OpenCode entrypoint while run-time commands decide the long-lived mode.
ENTRYPOINT ["opencode"]
