#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"
if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") <workspace-name-or-path>"
fi
require_podman
resolve_workspace "$1"
require_container
exec podman logs "$CONTAINER_NAME"
