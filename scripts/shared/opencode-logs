#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace>] [podman logs args...]
       $(basename "$0") -- [podman logs args...]

Description:
Show Podman logs for the resolved workspace container.

Behaviour:
- resolves the existing container target for the workspace
- with no <workspace>, prompt with workspace names from \\`OPENCODE_BASE_ROOT\\` in alphabetical order
- forwards all remaining arguments directly to \\`podman logs\\`

Arguments:
- <workspace> : workspace name
- [podman logs args...] : flags or arguments passed through to \\`podman logs\\`

Examples:
- $(basename "$0") demo
- $(basename "$0") demo --tail 50
- $(basename "$0") -- --tail 50
- $(basename "$0") demo -f

Notes:
- omitting \\`<workspace>\\` opens an alphabetical workspace picker from \\`OPENCODE_BASE_ROOT\\`
- when omitting \\`<workspace>\\`, use a leading \\`--\\` before any \\`podman logs\\` flags such as \\`--tail\\` or \\`-f\\`
- if more than one container target exists for the workspace, the command will prompt for the container to inspect."
fi

if [[ $# -gt 0 && "$1" != "--" ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
  shift
else
  WORKSPACE="$(resolve_workspace_argument '')"
  if [[ ${1-} == "--" ]]; then
    shift
  fi
fi
require_podman

CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")" || exit $?
exec podman logs "$@" "$CONTAINER_NAME"
