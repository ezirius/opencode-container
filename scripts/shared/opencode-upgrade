#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ $# -ne 0 ]]; then
  usage_error "$(basename "$0") takes no arguments"
fi

require_podman

if ! image_exists; then
  echo "==> OpenCode image not found: $OPENCODE_IMAGE_NAME"
  echo "==> Building image first"
  exec "$SCRIPT_DIR/opencode-build"
fi

require_python3

RESOLVED_UBUNTU_VERSION="$(resolve_ubuntu_version)"
RESOLVED_OPENCODE_VERSION="$(resolve_opencode_version)"
CURRENT_UBUNTU_VERSION="$(image_label opencode.ubuntu_version)"
CURRENT_OPENCODE_VERSION="$(image_label opencode.version)"

if [[ -n "$CURRENT_UBUNTU_VERSION" && -n "$CURRENT_OPENCODE_VERSION" && \
  "$CURRENT_UBUNTU_VERSION" == "$RESOLVED_UBUNTU_VERSION" && \
  "$CURRENT_OPENCODE_VERSION" == "$RESOLVED_OPENCODE_VERSION" ]]; then
  echo "==> OpenCode image already matches requested versions: $OPENCODE_IMAGE_NAME"
  echo "==> Ubuntu version:   $CURRENT_UBUNTU_VERSION"
  echo "==> OpenCode version: $CURRENT_OPENCODE_VERSION"
  echo "==> No upgrade needed"
  exit 0
fi

echo "==> Upgrading OpenCode image: $OPENCODE_IMAGE_NAME"
require_arm64_host
if [[ -n "$CURRENT_UBUNTU_VERSION" || -n "$CURRENT_OPENCODE_VERSION" ]]; then
  echo "==> Current Ubuntu version:   ${CURRENT_UBUNTU_VERSION:-unknown}"
  echo "==> Current OpenCode version: ${CURRENT_OPENCODE_VERSION:-unknown}"
else
  echo "==> Current image metadata is missing; rebuilding to refresh version tracking"
fi
echo "==> Target Ubuntu version:   $RESOLVED_UBUNTU_VERSION"
echo "==> Target OpenCode version: $RESOLVED_OPENCODE_VERSION"
podman image rm -f "$OPENCODE_IMAGE_NAME" >/dev/null
exec "$SCRIPT_DIR/opencode-build"
