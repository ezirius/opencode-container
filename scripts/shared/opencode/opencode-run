#!/usr/bin/env bash

set -euo pipefail

# This script starts one shared runtime plus one project container and attaches OpenCode there.

# This finds the repo root so the script can reach shared helpers.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/libs/shared/opencode/common.sh"

# This prints the supported command line for the run wrapper.
show_help() {
  cat <<'EOF'
Usage: scripts/shared/opencode/opencode-run [workspace] [project]

Start a configured workspace and attach OpenCode to the selected project container.
EOF
}

# This parses the small wrapper flag surface before positional workspace arguments.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      show_help
      exit 0
      ;;
    -*)
      printf 'Unsupported option: %s. See --help.\n' "$1" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -gt 2 ]]; then
  printf 'This script takes zero, one, or two arguments: [workspace] [project]. See --help.\n' >&2
  exit 1
fi

# This loads the saved workspace list only after help and argument checks succeed.
opencode_load_workspaces

# This warns about stale version pins before image lookup and container work begin.
opencode_warn_if_pinned_version_is_stale

image_name="$(opencode_latest_image)"
[[ -n "$image_name" ]] || fail 'No built OpenCode image found. Run scripts/shared/opencode/opencode-build first.'

if [[ $# -ge 1 ]]; then
  workspace="$1"
  opencode_validate_workspace_name "$workspace"
  opencode_workspace_offset "$workspace" >/dev/null
else
  workspace="$(opencode_pick_workspace)"
fi

if [[ $# -ge 2 ]]; then
  project_name="$(opencode_resolve_project_name "$2")"
else
  project_name="$(opencode_resolve_project_name '')"
fi

shared_container_name=''
published_port="$(opencode_workspace_published_port "$workspace")"
published_url="$(opencode_workspace_published_url "$workspace")"

host_home="$(opencode_host_home_dir "$workspace")"
host_workspace="$(opencode_host_workspace_dir "$workspace")"
development_root="$(opencode_expand_home_path "$OPENCODE_DEVELOPMENT_ROOT")"
project_root="$(project_root_dir "$project_name")"
old_containers="$(opencode_workspace_containers "$workspace")"
shared_container_name="$(opencode_shared_container_name "$image_name" "$workspace")"
container_name="$(opencode_container_name "$image_name" "$workspace" "$project_name")"
running_shared_container=''
existing_shared_container=''
reuse_existing=0
running_canonical_container=""
shared_runtime_created=0
shared_runtime_started=0

# This creates the shared runtime container that owns workspace-wide mounts and stable port publishing.
create_shared_runtime_container() {
  podman run -d \
    --name "$shared_container_name" \
    --userns keep-id \
    -w "$OPENCODE_CONTAINER_WORKSPACE" \
    -p "$published_port:$OPENCODE_SERVER_PORT" \
    -v "$host_home:$OPENCODE_CONTAINER_HOME" \
    -v "$host_workspace:$OPENCODE_CONTAINER_WORKSPACE" \
    -v "$development_root:$OPENCODE_CONTAINER_PROJECTS" \
    "$image_name" \
    serve --hostname "$OPENCODE_SERVER_HOSTNAME" --port "$OPENCODE_SERVER_PORT"
}

# This creates the project container with the current image and fixed mount contract.
create_workspace_container() {
  local target_container_name="$1"

  podman run -d \
    --name "$target_container_name" \
    --userns keep-id \
    -w "$OPENCODE_CONTAINER_PROJECT" \
    -v "$host_home:$OPENCODE_CONTAINER_HOME" \
    -v "$host_workspace:$OPENCODE_CONTAINER_WORKSPACE" \
    -v "$development_root:$OPENCODE_CONTAINER_DEVELOPMENT" \
    -v "$project_root:$OPENCODE_CONTAINER_PROJECT" \
    "$image_name" \
    serve --hostname "$OPENCODE_SERVER_HOSTNAME" --port "$OPENCODE_SERVER_PORT"
}

opencode_require_config_value "$OPENCODE_SERVER_HOSTNAME" 'OPENCODE_SERVER_HOSTNAME'

mkdir -p "$host_home" "$host_workspace"

if [[ "$(id -u)" == '0' ]]; then
  owner_uid="$(opencode_host_uid)"
  owner_gid="$(opencode_host_gid)"
  chown -R "$owner_uid:$owner_gid" "$host_home" "$host_workspace"
fi

# This makes sure the shared runtime exists before the project container flow begins.
if opencode_container_is_running "$shared_container_name"; then
  opencode_success "Reusing shared runtime container: $shared_container_name"
elif opencode_container_exists "$shared_container_name"; then
  opencode_success "Starting shared runtime container: $shared_container_name"
  podman start "$shared_container_name" >/dev/null
  shared_runtime_started=1
elif running_shared_container="$(opencode_running_shared_container "$workspace")" && [[ -n "$running_shared_container" ]]; then
  shared_container_name="$running_shared_container"
  opencode_success "Reusing shared runtime container: $shared_container_name"
elif existing_shared_container="$(opencode_existing_shared_container "$workspace")" && [[ -n "$existing_shared_container" ]]; then
  shared_container_name="$existing_shared_container"
  opencode_success "Starting shared runtime container: $shared_container_name"
  podman start "$shared_container_name" >/dev/null
  shared_runtime_started=1
else
  opencode_success "Creating shared runtime container: $shared_container_name"
  create_shared_runtime_container
  shared_runtime_created=1
fi

while IFS= read -r old_container; do
  [[ -n "$old_container" ]] || continue
  if [[ "$old_container" == "$container_name" ]]; then
    reuse_existing=1
    break
  fi
done <<< "$old_containers"

# This prefers the exact canonical name when it is already running before scanning sibling matches.
if [[ "$reuse_existing" == '1' ]]; then
  if opencode_container_is_running "$container_name"; then
    running_canonical_container="$container_name"
  else
    running_canonical_container=''
  fi
else
  running_canonical_container="$(opencode_running_container "$workspace" "$project_name")"
fi

if [[ -n "$running_canonical_container" ]]; then
  container_name="$running_canonical_container"
  reuse_existing=1
fi

if [[ "$reuse_existing" != '1' ]]; then
  opencode_success "Creating new container: $container_name"
  podman rm -f "$container_name" >/dev/null 2>&1 || true
  create_workspace_container "$container_name"
elif [[ -z "$running_canonical_container" ]]; then
  opencode_success "Starting existing container: $container_name"
  podman start "$container_name" >/dev/null 2>&1 || true
else
  opencode_success "Reusing running container: $container_name"
fi

while true; do
  if ! opencode_wait_for_running_container "$container_name"; then
    printf 'OpenCode container failed to stay running: %s\n' "$container_name" >&2
    opencode_print_container_startup_diagnostics "$container_name"
    exit 1
  fi

  if ! opencode_wait_for_stable_running_container "$container_name"; then
    printf 'OpenCode container stopped before attach: %s\n' "$container_name" >&2
    opencode_print_container_startup_diagnostics "$container_name"
    exit 1
  fi

  break
done

# This waits for the published host URL before best-effort host browser launch.
if [[ "$shared_runtime_created" == '1' || "$shared_runtime_started" == '1' ]]; then
  if opencode_wait_for_published_url "$published_url"; then
    opencode_open_published_url_detached "$published_url"
  fi
fi

opencode_exec_podman_interactive_command exec "$container_name" "$OPENCODE_DEFAULT_COMMAND" attach "$(opencode_attach_url)"
