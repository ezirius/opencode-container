#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace>] [command args...]
       $(basename "$0") [<workspace>] -- [command args...]
       $(basename "$0") [<workspace>] $(lane_usage_text) <upstream> [command args...]
       $(basename "$0") [<workspace>] $(lane_usage_text) <upstream> -- [command args...]
       $(basename "$0") -- $(lane_usage_text) <upstream> [command args...]
       $(basename "$0") -- -- [command args...]

Description:
Open a shell or run a command in the running OpenCode workspace container.

Behaviour:
- resolves the running container target for the workspace, or a specific lane/upstream container when given explicitly
- with no <workspace>, prompt with workspace names from \\`OPENCODE_BASE_ROOT\\` in alphabetical order
- with no command args, opens an interactive shell in the workspace directory
- with command args, execs that command in the workspace directory

Arguments:
- <workspace> : workspace name
- $(lane_usage_text) : optional explicit lane selector
- <upstream> : optional explicit upstream selector for an existing container target
- [command args...] : command and arguments to run inside the container

Examples:
- $(basename "$0") demo
- $(basename "$0") demo -- env
- $(basename "$0") -- -- env
- $(basename "$0") demo $OPENCODE_LANE_PRODUCTION $OPENCODE_VERSION -- env

Notes:
- use \\`--\\` when the first command argument would otherwise look like a wrapper selector such as \\`$OPENCODE_LANE_TEST\\` or \\`$OPENCODE_LANE_PRODUCTION\\`
- omitting \\`<workspace>\\` opens an alphabetical workspace picker from \\`OPENCODE_BASE_ROOT\\`
- when omitting \\`<workspace>\\`, use a leading \\`--\\` before explicit lane selectors or command arguments
- this command requires the resolved container to already be running."
fi

if [[ $# -gt 0 && "$1" != "--" ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
  shift
else
  WORKSPACE="$(resolve_workspace_argument '')"
  if [[ ${1-} == "--" ]]; then
    shift
  fi
fi
PAYLOAD_ONLY=0

if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# == 1 ]] && is_lane "$1"; then
  usage_error "$(basename "$0") <workspace> $(lane_usage_text) <upstream> [command args...]"
fi

require_podman

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 ]] && is_lane "$1"; then
  CONTAINER_NAME="$(resolve_existing_explicit_container "$WORKSPACE" "$1" "$2")" || exit $?
  shift 2
  if [[ ${1-} == "--" ]]; then
    shift
  fi
else
  CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")" || exit $?
fi

container_running "$CONTAINER_NAME" || fail "container is not running: $CONTAINER_NAME"
exec_shell_in_container "$CONTAINER_NAME" "$@"
