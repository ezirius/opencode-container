#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace> [command args...]
       $(basename "$0") <workspace> -- [command args...]
       $(basename "$0") <workspace> <production|test> <upstream> [command args...]
       $(basename "$0") <workspace> <production|test> <upstream> -- [command args...]

Description:
Open a shell or run a command in the running OpenCode workspace container.

Behaviour:
- resolves the running container target for the workspace, or a specific lane/upstream container when given explicitly
- with no command args, opens an interactive shell in the workspace directory
- with command args, execs that command in the workspace directory

Arguments:
- <workspace> : workspace name
- <production|test> : optional explicit lane selector
- <upstream> : optional explicit upstream selector for an existing container target
- [command args...] : command and arguments to run inside the container

Examples:
- $(basename "$0") demo
- $(basename "$0") demo -- env
- $(basename "$0") demo production 1.4.3 -- env

Notes:
- use \\`--\\` when the first command argument would otherwise look like a wrapper selector such as \\`test\\` or \\`production\\`
- this command requires the resolved container to already be running."
fi

[[ $# -ge 1 ]] || usage_error "$(basename "$0") <workspace> [command args...]"
WORKSPACE="$1"
shift
require_workspace_name "$WORKSPACE"
PAYLOAD_ONLY=0

if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# == 1 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  usage_error "$(basename "$0") <workspace> <production|test> <upstream> [command args...]"
fi

require_podman

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  CONTAINER_NAME="$(resolve_existing_explicit_container "$WORKSPACE" "$1" "$2")"
  shift 2
  if [[ ${1-} == "--" ]]; then
    shift
  fi
else
  CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")"
fi

container_running "$CONTAINER_NAME" || fail "container is not running: $CONTAINER_NAME"
exec_shell_in_container "$CONTAINER_NAME" "$@"
