#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"
if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") <workspace-name-or-path>"
fi
require_podman
resolve_workspace "$1"
require_running_container
if use_exec_tty; then
  exec podman exec -it -w /workspace "$CONTAINER_NAME" /bin/bash
else
  exec podman exec -i -w /workspace "$CONTAINER_NAME" /bin/bash
fi
