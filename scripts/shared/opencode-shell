#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace> [command args...]
       $(basename "$0") <workspace> <production|test> <upstream> [command args...]

Open a shell or run a command in the running OpenCode workspace container."
fi

[[ $# -ge 1 ]] || usage_error "$(basename "$0") <workspace> [command args...]"
WORKSPACE="$1"
shift
require_workspace_name "$WORKSPACE"
require_podman

if [[ $# -ge 2 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  CONTAINER_NAME="$(resolve_existing_explicit_container "$WORKSPACE" "$1" "$2")"
  shift 2
else
  CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")"
fi

container_running "$CONTAINER_NAME" || fail "container is not running: $CONTAINER_NAME"
exec_shell_in_container "$CONTAINER_NAME" "$@"
