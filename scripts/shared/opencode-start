#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace>] [project] [opencode args...]
       $(basename "$0") [<workspace>] [project] -- [opencode args...]
       $(basename "$0") [<workspace>] $(lane_usage_text) <upstream> [project] [opencode args...]
       $(basename "$0") [<workspace>] $(lane_usage_text) <upstream> [project] -- [opencode args...]
       $(basename "$0") -- $(lane_usage_text) <upstream> [project] [opencode args...]
       $(basename "$0") -- -- [opencode args...]

Description:
Start or reuse a persistent OpenCode workspace container.

Behaviour:
- with only <workspace>, resolve the preferred target for that workspace and start or reuse it
- with no <workspace>, prompt with workspace names from \`OPENCODE_BASE_ROOT\` in alphabetical order
- with an explicit lane and upstream, select the matching local image and start or recreate the matching container
- after target resolution, require a direct-child project from \`OPENCODE_DEVELOPMENT_ROOT\`, using an explicit \`[project]\` when provided or the project picker otherwise
- any remaining arguments are forwarded to the in-container \`opencode\` command after the container is ready

Arguments:
- <workspace> : workspace name
- $(lane_usage_text) : optional explicit lane selector
- <upstream> : optional explicit upstream selector; accepted values are \`$OPENCODE_UPSTREAM_MAIN_SELECTOR\`, \`$OPENCODE_DEFAULT_UPSTREAM_SELECTOR\`, or an exact stable release tag
- [project] : optional explicit direct-child project name under \`OPENCODE_DEVELOPMENT_ROOT\`; if omitted, the wrapper prompts for one
- [opencode args...] : arguments forwarded to the in-container \`opencode\` command

Examples:
- $(basename "$0") demo
- $(basename "$0") demo $OPENCODE_LANE_PRODUCTION $OPENCODE_VERSION beta
- $(basename "$0") -- $OPENCODE_LANE_TEST $OPENCODE_VERSION
- $(basename "$0") demo $OPENCODE_LANE_PRODUCTION $OPENCODE_VERSION -- --help

Notes:
- use \`--\` when the first forwarded argument would otherwise look like a wrapper selector such as \`$OPENCODE_LANE_TEST\` or \`$OPENCODE_LANE_PRODUCTION\`
- omitting \`<workspace>\` opens an alphabetical workspace picker from \`OPENCODE_BASE_ROOT\`
- omitting \`[project]\` opens an alphabetical direct-child project picker from \`OPENCODE_DEVELOPMENT_ROOT\`
- when omitting \`[project]\` and forwarding payload arguments, use \`--\` before the payload so the wrapper prompts for a project before parsing payload arguments
- when omitting \`<workspace>\`, a leading \`--\` selects the picker first so explicit lane selectors or forwarded arguments are parsed after the workspace choice
- the mounted $OPENCODE_WORKSPACE_CONFIG_SUBDIR/config.env file is snapshotted when the container starts
- optional $OPENCODE_WORKSPACE_CONFIG_SUBDIR/secrets.env is snapshotted second
- if you change either file, restart the container to apply the new values."
fi

if [[ $# -gt 0 && "$1" != "--" ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
  shift
else
  WORKSPACE="$(resolve_workspace_argument '')"
  if [[ ${1-} == "--" ]]; then
    shift
  fi
fi
PAYLOAD_ONLY=0

if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# == 1 ]] && is_lane "$1" && ! project_name_exists "$1"; then
  usage_error "$(basename "$0") <workspace> $(lane_usage_text) <upstream> [opencode args...]"
fi

require_podman
ensure_workspace_layout "$WORKSPACE"
seed_workspace_config_env_file "$WORKSPACE"

consume_project_selection() {
  if [[ "$PAYLOAD_ONLY" == "0" && $# -gt 0 && "${1-}" != "--" ]]; then
    PROJECT_NAME="$(resolve_selected_project_name "$1")"
    shift
  else
    PROJECT_NAME="$(resolve_selected_project_name '')"
  fi
  if [[ ${1-} == "--" ]]; then
    shift
  fi
  REMAINING_ARGS=("$@")
}

REMAINING_ARGS=("$@")

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 ]] && is_lane "$1"; then
  LANE="$1"
  UPSTREAM_SELECTOR="$2"
  shift 2
  validate_lane "$LANE"
  validate_upstream_selector "$UPSTREAM_SELECTOR"
  WRAPPER_CONTEXT="$(current_wrapper_context)"
  UPSTREAM_RESOLVED="$(resolve_upstream_selector "$UPSTREAM_SELECTOR")"
  IMAGE_REF="$(newest_matching_image_ref "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" 2>/dev/null || true)"
  [[ -n "$IMAGE_REF" ]] || fail "no local image found for lane=$LANE upstream=$UPSTREAM_RESOLVED wrapper=$WRAPPER_CONTEXT (run opencode-build first)"
  COMMITSTAMP="$(image_label "$IMAGE_REF" "$OPENCODE_LABEL_COMMITSTAMP")"
  consume_project_selection "$@"
  CONTAINER_NAME="$(container_name "$WORKSPACE" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$PROJECT_NAME")"
  if [[ ${#REMAINING_ARGS[@]} -gt 0 ]]; then
    set -- "${REMAINING_ARGS[@]}"
  else
    set --
  fi
  ensure_running_container_matches_image_and_runtime "$CONTAINER_NAME" "$IMAGE_REF" "$WORKSPACE" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$COMMITSTAMP" "$PROJECT_NAME"
else
  TARGET_ROW="$(resolve_target_details_for_workspace "$WORKSPACE")"
  IFS=$'\t' read -r TARGET_KIND TARGET_REF LANE UPSTREAM_RESOLVED WRAPPER_CONTEXT COMMITSTAMP _STATUS _IMAGE_REF <<< "$TARGET_ROW"
  consume_project_selection "$@"
  if [[ ${#REMAINING_ARGS[@]} -gt 0 ]]; then
    set -- "${REMAINING_ARGS[@]}"
  else
    set --
  fi
  CONTAINER_NAME="$(start_or_reuse_target "$WORKSPACE" "$TARGET_KIND" "$TARGET_REF" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$COMMITSTAMP" "$PROJECT_NAME")"
fi

if [[ $# -gt 0 ]]; then
  exec_opencode_in_container "$CONTAINER_NAME" "$@"
fi

print_container_summary "$WORKSPACE" "$CONTAINER_NAME"
