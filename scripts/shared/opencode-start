#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"
if [[ $# -ne 1 ]]; then
  usage_error "$(basename "$0") requires exactly 1 argument: <workspace-name-or-path>"
fi
require_podman
require_arm64_host
resolve_workspace "$1"
ensure_workspace_dirs
print_workspace_summary
if ! image_exists; then
  fail "image not found: $OPENCODE_IMAGE_NAME (run $SCRIPT_DIR/opencode-build first)"
fi
if container_exists; then
  if container_running; then
    if [[ "$(container_image_id)" == "$(image_id)" ]]; then
      echo "==> Container already running: $CONTAINER_NAME"
      exit 0
    fi
    echo "==> Recreating running container with updated local image: $CONTAINER_NAME"
    podman rm -f "$CONTAINER_NAME" >/dev/null
  elif [[ "$(container_image_id)" != "$(image_id)" ]]; then
    echo "==> Removing existing container with old image: $CONTAINER_NAME"
    podman rm -f "$CONTAINER_NAME" >/dev/null
  else
    echo "==> Starting existing stopped container: $CONTAINER_NAME"
    podman start "$CONTAINER_NAME" >/dev/null
    echo "==> Container started: $CONTAINER_NAME"
    printf '==> Open OpenCode with: %q %q\n' "$SCRIPT_DIR/opencode-open" "$WORKSPACE_INPUT"
    printf '==> Open a shell with:  %q %q\n' "$SCRIPT_DIR/opencode-shell" "$WORKSPACE_INPUT"
    exit 0
  fi
fi
echo "==> Starting idle OpenCode container"
podman run -d \
  --name "$CONTAINER_NAME" \
  --platform="linux/arm64" \
  -v "$WORKSPACE_ROOT:/workspace" \
  -v "$CONFIG_DIR:/configurations" \
  -v "$DATA_DIR:/data" \
  -w /workspace \
  "$OPENCODE_IMAGE_NAME" >/dev/null
echo "==> Container started: $CONTAINER_NAME"
printf '==> Open OpenCode with: %q %q\n' "$SCRIPT_DIR/opencode-open" "$WORKSPACE_INPUT"
printf '==> Open a shell with:  %q %q\n' "$SCRIPT_DIR/opencode-shell" "$WORKSPACE_INPUT"
