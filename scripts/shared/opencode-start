#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace> [opencode args...]
       $(basename "$0") <workspace> -- [opencode args...]
       $(basename "$0") <workspace> <production|test> <upstream> [opencode args...]
       $(basename "$0") <workspace> <production|test> <upstream> -- [opencode args...]

Start or reuse a persistent OpenCode workspace container.

The mounted .config/opencode/config.env file is snapshotted when the container starts.
Optional .config/opencode/secrets.env is snapshotted second.
If you change either file, restart the container to apply the new values."
fi

[[ $# -ge 1 ]] || usage_error "$(basename "$0") <workspace> [<production|test> <upstream>] [opencode args...]"

WORKSPACE="$1"
shift
require_workspace_name "$WORKSPACE"
require_podman
ensure_workspace_layout "$WORKSPACE"
seed_workspace_config_env_file "$WORKSPACE"
PAYLOAD_ONLY=0

if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  LANE="$1"
  UPSTREAM_SELECTOR="$2"
  shift 2
  if [[ ${1-} == "--" ]]; then
    shift
  fi
  validate_lane "$LANE"
  validate_upstream_selector "$UPSTREAM_SELECTOR"
  WRAPPER_CONTEXT="$(current_wrapper_context)"
  UPSTREAM_RESOLVED="$(resolve_upstream_selector "$UPSTREAM_SELECTOR")"
  IMAGE_REF="$(newest_matching_image_ref "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" 2>/dev/null || true)"
  [[ -n "$IMAGE_REF" ]] || fail "no local image found for lane=$LANE upstream=$UPSTREAM_RESOLVED wrapper=$WRAPPER_CONTEXT (run opencode-build first)"
  COMMITSTAMP="$(image_label "$IMAGE_REF" "$OPENCODE_LABEL_COMMITSTAMP")"
  CONTAINER_NAME="$(container_name "$WORKSPACE" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT")"
  ensure_running_container_matches_image_and_runtime "$CONTAINER_NAME" "$IMAGE_REF" "$WORKSPACE" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$COMMITSTAMP"
else
  TARGET_ROW="$(resolve_target_details_for_workspace "$WORKSPACE")"
  IFS=$'\t' read -r TARGET_KIND TARGET_REF LANE UPSTREAM_RESOLVED WRAPPER_CONTEXT COMMITSTAMP _STATUS _IMAGE_REF <<< "$TARGET_ROW"
  CONTAINER_NAME="$(start_or_reuse_target "$WORKSPACE" "$TARGET_KIND" "$TARGET_REF" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$COMMITSTAMP")"
fi

if [[ $# -gt 0 ]]; then
  exec env OPENCODE_WRAPPER_CONTEXT_OVERRIDE="$WRAPPER_CONTEXT" "$SCRIPT_DIR/opencode-open" "$WORKSPACE" "$LANE" "$UPSTREAM_RESOLVED" "$@"
fi

print_container_summary "$WORKSPACE" "$CONTAINER_NAME"
