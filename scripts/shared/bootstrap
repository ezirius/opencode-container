#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") <workspace-name-or-path> [opencode args...]"
fi

WORKSPACE_INPUT="$1"
shift || true

"$SCRIPT_DIR/opencode-build"
"$SCRIPT_DIR/opencode-start" "$WORKSPACE_INPUT"
exec "$SCRIPT_DIR/opencode-open" "$WORKSPACE_INPUT" "$@"
