#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace> [opencode args...]
       $(basename "$0") <workspace> -- [opencode args...]
       $(basename "$0") <workspace> <production|test> <upstream> [opencode args...]
       $(basename "$0") <workspace> <production|test> <upstream> -- [opencode args...]

Open OpenCode by execing into the running container for one workspace."
fi

[[ $# -ge 1 ]] || usage_error "$(basename "$0") <workspace> [<production|test> <upstream>] [opencode args...]"
WORKSPACE="$1"
shift
require_workspace_name "$WORKSPACE"
PAYLOAD_ONLY=0

if [[ ${1-} == "--" ]]; then
  shift
  PAYLOAD_ONLY=1
fi

if [[ "$PAYLOAD_ONLY" == "0" && $# == 1 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  usage_error "$(basename "$0") <workspace> <production|test> <upstream> [opencode args...]"
fi

require_podman

if [[ "$PAYLOAD_ONLY" == "0" && $# -ge 2 && ( "$1" == "production" || "$1" == "test" ) ]]; then
  CONTAINER_NAME="$(resolve_existing_explicit_container "$WORKSPACE" "$1" "$2")"
  shift 2
  if [[ ${1-} == "--" ]]; then
    shift
  fi
else
  CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")"
fi

container_running "$CONTAINER_NAME" || fail "container is not running: $CONTAINER_NAME"
exec_opencode_in_container "$CONTAINER_NAME" "$@"
