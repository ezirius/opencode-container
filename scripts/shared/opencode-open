#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"
if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") requires at least 1 argument: <workspace-name-or-path> [opencode args...]"
fi
require_podman
resolve_workspace "$1"
shift || true
require_running_container
if use_exec_tty; then
  exec podman exec -it -w /workspace "$CONTAINER_NAME" opencode "$@"
else
  exec podman exec -i -w /workspace "$CONTAINER_NAME" opencode "$@"
fi
