#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"
if [[ $# -lt 1 ]]; then
  usage_error "$(basename "$0") <workspace-name-or-path> [opencode args...]"
fi
require_podman
resolve_workspace "$1"
shift || true
require_running_container
EXEC_FLAGS="$(podman_exec_flags)"
exec podman exec "$EXEC_FLAGS" -w /workspace "$CONTAINER_NAME" opencode "$@"
