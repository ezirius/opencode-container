#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [containers|images]

Description:
Remove OpenCode project containers and images.

Behaviour:
- with no argument, show a mixed picker with containers first and then images
- with \\`containers\\`, show only container targets
- with \\`images\\`, show only image targets
- \\`All\\` removes all selected target types
- mixed-mode \\`All\\` removes all containers first and then all images
- \\`All, but newest\\` keeps one preferred container per workspace, where \\`production\\` beats \\`test\\` and commit timestamp breaks ties within a lane
- image retention keeps the image serving each kept container

Arguments:
- [containers|images] : optional mode selector; omit for mixed mode

Examples:
- $(basename "$0")
- $(basename "$0") containers
- $(basename "$0") images

Notes:
- mixed mode lists containers before images
- individual selections remove only the selected target."
fi

[[ $# -le 1 ]] || usage_error "$(basename "$0") [containers|images]"
MODE="${1:-mixed}"
[[ "$MODE" == "mixed" || "$MODE" == "containers" || "$MODE" == "images" ]] || fail "mode must be 'mixed', 'containers', or 'images'"
require_podman

container_lane_rank() {
  local lane="$1"
  if [[ "$lane" == "production" ]]; then
    printf '0'
  else
    printf '1'
  fi
}

sorted_container_rows_for_retention() {
  project_container_rows | while IFS=$'\t' read -r name workspace lane upstream wrapper commitstamp status image_ref; do
    [[ -n "$name" && -n "$workspace" ]] || continue
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$workspace" "$(container_lane_rank "$lane")" "$commitstamp" "$name" "$lane" "$upstream" "$wrapper" "$status" "$image_ref"
  done | sort -t $'\t' -k1,1 -k2,2n -k3,3r
}

kept_container_rows() {
  local current_workspace=""
  sorted_container_rows_for_retention | while IFS=$'\t' read -r workspace _lane_rank commitstamp name lane upstream wrapper status image_ref; do
    [[ -n "$name" ]] || continue
    if [[ "$workspace" != "$current_workspace" ]]; then
      current_workspace="$workspace"
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$name" "$workspace" "$lane" "$upstream" "$wrapper" "$commitstamp" "$status" "$image_ref"
    fi
  done
}

kept_container_names() {
  kept_container_rows | while IFS=$'\t' read -r name _workspace _lane _upstream _wrapper _commitstamp _status _image_ref; do
    [[ -n "$name" ]] || continue
    printf '%s\n' "$name"
  done
}

kept_image_refs() {
  kept_container_rows | while IFS=$'\t' read -r _name _workspace _lane _upstream _wrapper _commitstamp _status image_ref; do
    [[ -n "$image_ref" ]] || continue
    printf '%s\n' "$image_ref"
  done | sort -u
}

line_in_list() {
  local line="$1"
  local list="$2"
  contains_line "$list" "$line"
}

container_picker_options() {
  local rows="$1"
  while IFS=$'\t' read -r name workspace lane upstream wrapper commitstamp status _image_ref; do
    [[ -n "$name" ]] || continue
    printf 'container | %s | %s | %s | %s | %s | %s | %s\n' "$name" "$workspace" "$lane" "$upstream" "$wrapper" "$commitstamp" "$status"
  done <<< "$rows"
}

image_picker_options() {
  local rows="$1"
  while IFS=$'\t' read -r ref lane upstream wrapper commitstamp; do
    [[ -n "$ref" ]] || continue
    printf 'image | %s | %s | %s | %s | %s\n' "$ref" "$lane" "$upstream" "$wrapper" "$commitstamp"
  done <<< "$rows"
}

selected_option_id() {
  local option="$1"
  local _type _id
  IFS='|' read -r _type _id _rest <<< "$option"
  _id="${_id# }"
  _id="${_id% }"
  printf '%s' "$_id"
}

remove_all_containers() {
  local rows="$1"
  local name
  while IFS=$'\t' read -r name _workspace _lane _upstream _wrapper _commitstamp _status _image_ref; do
    [[ -n "$name" ]] || continue
    podman rm -f "$name" >/dev/null
    printf 'Removed container: %s\n' "$name"
  done <<< "$rows"
}

remove_all_images() {
  local rows="$1"
  local ref
  while IFS=$'\t' read -r ref _lane _upstream _wrapper _commitstamp; do
    [[ -n "$ref" ]] || continue
    podman rmi "$ref" >/dev/null
    printf 'Removed image: %s\n' "$ref"
  done <<< "$rows"
}

remove_containers_keep_newest() {
  local rows="$1"
  local keep_names="$2"
  local name
  while IFS=$'\t' read -r name _workspace _lane _upstream _wrapper _commitstamp _status _image_ref; do
    [[ -n "$name" ]] || continue
    if line_in_list "$name" "$keep_names"; then
      printf 'Keeping container: %s\n' "$name"
    else
      podman rm -f "$name" >/dev/null
      printf 'Removed container: %s\n' "$name"
    fi
  done <<< "$rows"
}

remove_images_keep_newest() {
  local rows="$1"
  local keep_refs="$2"
  local ref
  while IFS=$'\t' read -r ref _lane _upstream _wrapper _commitstamp; do
    [[ -n "$ref" ]] || continue
    if line_in_list "$ref" "$keep_refs"; then
      printf 'Keeping image: %s\n' "$ref"
    else
      podman rmi "$ref" >/dev/null
      printf 'Removed image: %s\n' "$ref"
    fi
  done <<< "$rows"
}

remove_containers() {
  local rows selection choice_index
  local options=()
  local name keep_names selected
  rows="$(sorted_project_container_rows)"
  [[ -n "$rows" ]] || fail "no OpenCode project containers found"

  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    options+=("$name")
  done < <(container_picker_options "$rows")

  selection="$(select_menu_option "Select containers to remove" "All, but newest" "All" "${options[@]}")"
  choice_index=$((selection - 1))

  if (( choice_index == 0 )); then
    keep_names="$(kept_container_names)"
    remove_containers_keep_newest "$rows" "$keep_names"
    return 0
  fi

  if (( choice_index == 1 )); then
    remove_all_containers "$rows"
    return 0
  fi

  selected="${options[$((choice_index - 2))]}"
  name="$(selected_option_id "$selected")"
  podman rm -f "$name" >/dev/null
  printf 'Removed container: %s\n' "$name"
}

remove_images() {
  local rows selection choice_index
  local options=()
  local ref keep_refs selected
  rows="$(sorted_project_image_rows)"
  [[ -n "$rows" ]] || fail "no OpenCode project images found"

  while IFS= read -r ref; do
    [[ -n "$ref" ]] || continue
    options+=("$ref")
  done < <(image_picker_options "$rows")

  selection="$(select_menu_option "Select images to remove" "All, but newest" "All" "${options[@]}")"
  choice_index=$((selection - 1))

  if (( choice_index == 0 )); then
    keep_refs="$(kept_image_refs)"
    remove_images_keep_newest "$rows" "$keep_refs"
    return 0
  fi

  if (( choice_index == 1 )); then
    remove_all_images "$rows"
    return 0
  fi

  selected="${options[$((choice_index - 2))]}"
  ref="$(selected_option_id "$selected")"
  podman rmi "$ref" >/dev/null
  printf 'Removed image: %s\n' "$ref"
}

remove_mixed() {
  local container_rows image_rows prompt selection choice_index
  local options=()
  local line keep_names keep_refs selected

  container_rows="$(sorted_project_container_rows)"
  image_rows="$(sorted_project_image_rows)"
  [[ -n "$container_rows$image_rows" ]] || fail "no OpenCode project containers or images found"

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    options+=("$line")
  done < <(container_picker_options "$container_rows")

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    options+=("$line")
  done < <(image_picker_options "$image_rows")

  prompt="Select containers or images to remove"
  selection="$(select_menu_option "$prompt" "All, but newest" "All" "${options[@]}")"
  choice_index=$((selection - 1))

  if (( choice_index == 0 )); then
    keep_names="$(kept_container_names)"
    keep_refs="$(kept_image_refs)"
    [[ -n "$container_rows" ]] && remove_containers_keep_newest "$container_rows" "$keep_names"
    [[ -n "$image_rows" ]] && remove_images_keep_newest "$image_rows" "$keep_refs"
    return 0
  fi

  if (( choice_index == 1 )); then
    [[ -n "$container_rows" ]] && remove_all_containers "$container_rows"
    [[ -n "$image_rows" ]] && remove_all_images "$image_rows"
    return 0
  fi

  selected="${options[$((choice_index - 2))]}"
  if [[ "$selected" == container* ]]; then
    selected="$(selected_option_id "$selected")"
    while IFS=$'\t' read -r name _workspace _lane _upstream _wrapper _commitstamp _status _image_ref; do
      [[ -n "$name" ]] || continue
      if [[ "$selected" == "$name" ]]; then
        podman rm -f "$name" >/dev/null
        printf 'Removed container: %s\n' "$name"
        return 0
      fi
    done <<< "$container_rows"
  else
    selected="$(selected_option_id "$selected")"
    while IFS=$'\t' read -r ref _lane _upstream _wrapper _commitstamp; do
      [[ -n "$ref" ]] || continue
      if [[ "$selected" == "$ref" ]]; then
        podman rmi "$ref" >/dev/null
        printf 'Removed image: %s\n' "$ref"
        return 0
      fi
    done <<< "$image_rows"
  fi

  fail "failed to resolve selected removal target"
}

if [[ "$MODE" == "containers" ]]; then
  remove_containers
elif [[ "$MODE" == "images" ]]; then
  remove_images
else
  remove_mixed
fi
