#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") <workspace>

Description:
Stop the resolved workspace container if it is running.

Behaviour:
- resolves the existing container target for the workspace
- stops it when running
- reports when the resolved container is already stopped

Arguments:
- <workspace> : workspace name

Examples:
- $(basename "$0") demo

Notes:
- if more than one container target exists for the workspace, the command will prompt for which container to stop."
fi

[[ $# -eq 1 ]] || usage_error "$(basename "$0") <workspace>"
WORKSPACE="$1"
require_workspace_name "$WORKSPACE"
require_podman

CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")"
if container_running "$CONTAINER_NAME"; then
  podman stop "$CONTAINER_NAME" >/dev/null
  printf 'Stopped container: %s\n' "$CONTAINER_NAME"
else
  printf 'Container already stopped: %s\n' "$CONTAINER_NAME"
fi
