#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") [<workspace>]

Description:
Stop the resolved workspace container if it is running.

Behaviour:
- resolves the existing container target for the workspace
- with no <workspace>, prompt with workspace names from OPENCODE_BASE_ROOT in alphabetical order
- stops it when running
- reports when the resolved container is already stopped

Arguments:
- <workspace> : workspace name

Examples:
- $(basename "$0") demo

Notes:
- omitting <workspace> opens an alphabetical workspace picker from OPENCODE_BASE_ROOT
- the command will prompt for which container to stop, even when only one matching container exists."
fi

[[ $# -le 1 ]] || usage_error "$(basename "$0") [<workspace>]"
if [[ $# -eq 1 ]]; then
  WORKSPACE="$(resolve_workspace_argument "$1")"
else
  WORKSPACE="$(resolve_workspace_argument '')"
fi
require_podman

CONTAINER_NAME="$(resolve_container_for_workspace "$WORKSPACE")" || exit $?
if container_running "$CONTAINER_NAME"; then
  podman stop "$CONTAINER_NAME" >/dev/null
  printf 'Stopped container: %s\n' "$CONTAINER_NAME"
else
  printf 'Container already stopped: %s\n' "$CONTAINER_NAME"
fi
