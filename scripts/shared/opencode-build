#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
source "$ROOT/lib/shell/common.sh"

if [[ ${1-} == "--help" ]]; then
  show_help "Usage: $(basename "$0") $(lane_usage_text) [upstream]

Build an immutable local Ubuntu-based OpenCode wrapper image.

If the lane is omitted, the wrapper prompts for the configured production or test lane.
If [upstream] is omitted, the wrapper prompts for an upstream version.

Accepted [upstream] values:
- $OPENCODE_UPSTREAM_MAIN_SELECTOR
- $OPENCODE_DEFAULT_UPSTREAM_SELECTOR
- an exact stable release tag"
fi

[[ $# -le 2 ]] || usage_error "$(basename "$0") $(lane_usage_text) [upstream]"

require_podman
require_python3

if [[ $# -ge 1 ]]; then
  LANE="$1"
else
  LANE="$(select_lane)"
fi

validate_build_context "$LANE"

if [[ $# -ge 2 ]]; then
  UPSTREAM_SELECTOR="$2"
else
  UPSTREAM_SELECTOR="$(select_upstream_selector)"
fi

validate_upstream_selector "$UPSTREAM_SELECTOR"
notify_if_newer_ubuntu_lts_exists

WRAPPER_CONTEXT="$(current_wrapper_context "$ROOT")"
COMMITSTAMP="$(git_commitstamp "$ROOT")"
UPSTREAM_RESOLVED="$(resolve_upstream_selector "$UPSTREAM_SELECTOR")"
UPSTREAM_REF="$(upstream_ref_for_selector "$UPSTREAM_SELECTOR")"
TARGET_IMAGE="$(image_ref "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$COMMITSTAMP")"

if image_exists "$TARGET_IMAGE"; then
  printf 'Image already exists: %s\n' "$TARGET_IMAGE"
  exit 0
fi

if [[ "$UPSTREAM_RESOLVED" == "$OPENCODE_UPSTREAM_MAIN_SELECTOR" ]]; then
  build_source_image "$UPSTREAM_REF" "$TARGET_IMAGE" "$LANE" "$UPSTREAM_RESOLVED" "$WRAPPER_CONTEXT" "$COMMITSTAMP"
  printf 'Build source: upstream source ref %s\n' "$UPSTREAM_REF"
else
  RELEASE_URL="$(release_binary_package_url "$UPSTREAM_RESOLVED")"
  RELEASE_SHA512="$(release_binary_package_sha512_hex "$UPSTREAM_RESOLVED")"
  build_release_image "$RELEASE_URL" "$RELEASE_SHA512" "$TARGET_IMAGE" "$LANE" "$UPSTREAM_RESOLVED" "$UPSTREAM_REF" "$WRAPPER_CONTEXT" "$COMMITSTAMP"
  printf 'Build source: official release %s\n' "$UPSTREAM_REF"
fi

printf 'Built image: %s\n' "$TARGET_IMAGE"
