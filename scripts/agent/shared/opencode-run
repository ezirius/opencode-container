#!/usr/bin/env bash

set -euo pipefail

# This script starts one saved workspace container and opens OpenCode inside it.

# This finds the repo root so the script can reach shared helpers.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

# This loads the saved workspace list before the script picks or validates a workspace.
opencode_load_workspaces

publish_external=0

# This parses the small wrapper flag surface before positional workspace arguments.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --publish)
      publish_external=1
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'Unsupported option: %s\n' "$1" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -gt 2 ]]; then
  printf 'This script takes an optional --publish flag plus zero, one, or two arguments: [workspace] [project].\n' >&2
  exit 1
fi

image_name="$(opencode_latest_image)"
[[ -n "$image_name" ]] || fail 'No built OpenCode image found. Run scripts/agent/shared/opencode-build first.'
image_short_id="$(opencode_latest_image_short_id)"
[[ -n "$image_short_id" ]] || fail 'No built OpenCode image id found. Run scripts/agent/shared/opencode-build first.'

if [[ $# -ge 1 ]]; then
  workspace="$1"
  opencode_validate_workspace_name "$workspace"
  opencode_workspace_offset "$workspace" >/dev/null
else
  workspace="$(opencode_pick_workspace)"
fi

if [[ $# -ge 2 ]]; then
  project_name="$(opencode_resolve_project_name "$2")"
else
  project_name="$(opencode_resolve_project_name '')"
fi

published_port=''
published_url=''

if [[ "$publish_external" == '1' ]]; then
  published_port="$(opencode_workspace_published_port "$workspace")"
  published_url="$(opencode_workspace_published_url "$workspace")"
fi

host_home="$(opencode_host_home_dir "$workspace")"
host_workspace="$(opencode_host_workspace_dir "$workspace")"
project_root="$(project_root_dir "$project_name")"
old_containers="$(opencode_workspace_containers "$workspace")"
container_name="$(opencode_workspace_container_name "$image_name" "$image_short_id" "$workspace")"
launch_container_name="$container_name"
reuse_existing=0
matching_running_container=""
recreated_exact_match_container=0
rename_after_start=0
created_workspace_container=0
started_workspace_container=0

# This creates the workspace container with the current image and fixed mount contract.
create_workspace_container() {
  local target_container_name="$1"

  # This publishes the stable host port only when the current run asked for external access.
  if [[ "$publish_external" == '1' ]]; then
    podman run -d \
      --name "$target_container_name" \
      --userns keep-id \
      -w "$OPENCODE_CONTAINER_PROJECT" \
      -p "$published_port:4096" \
      -v "$host_home:$OPENCODE_CONTAINER_HOME" \
      -v "$host_workspace:$OPENCODE_CONTAINER_WORKSPACE" \
      -v "$OPENCODE_DEVELOPMENT_ROOT:$OPENCODE_CONTAINER_DEVELOPMENT" \
      -v "$project_root:$OPENCODE_CONTAINER_PROJECT" \
      "$image_name" \
      serve --hostname 0.0.0.0 --port 4096
    created_workspace_container=1
    return
  fi

  podman run -d \
    --name "$target_container_name" \
    --userns keep-id \
    -w "$OPENCODE_CONTAINER_PROJECT" \
    -v "$host_home:$OPENCODE_CONTAINER_HOME" \
    -v "$host_workspace:$OPENCODE_CONTAINER_WORKSPACE" \
    -v "$OPENCODE_DEVELOPMENT_ROOT:$OPENCODE_CONTAINER_DEVELOPMENT" \
    -v "$project_root:$OPENCODE_CONTAINER_PROJECT" \
    "$image_name" \
    serve --hostname 0.0.0.0 --port 4096
  created_workspace_container=1
}

mkdir -p "$host_home" "$host_workspace"

if [[ "$(id -u)" == '0' ]]; then
  owner_uid="$(opencode_host_uid)"
  owner_gid="$(opencode_host_gid)"
  chown -R "$owner_uid:$owner_gid" "$host_home" "$host_workspace"
fi

while IFS= read -r old_container; do
  [[ -n "$old_container" ]] || continue
  if [[ "$old_container" == "$container_name" ]]; then
    reuse_existing=1
    break
  fi
done <<< "$old_containers"

matching_running_container="$(podman ps --format '{{.Names}}' --filter "name=$(opencode_container_name_regex "$container_name")" | head -n 1)"

if [[ "$reuse_existing" == '1' ]]; then
  if ! opencode_container_project_matches "$container_name" "$project_name" || ! opencode_container_workspace_matches "$container_name" "$workspace" || ! opencode_container_publish_matches "$container_name" "$workspace" "$publish_external"; then
    reuse_existing=0
    matching_running_container=""
    rename_after_start=1
    launch_container_name="$container_name-next-$$"
  fi
fi

if [[ "$reuse_existing" != '1' ]]; then
  create_workspace_container "$launch_container_name"
elif [[ "$matching_running_container" != "$container_name" ]]; then
  if podman start "$container_name" >/dev/null 2>&1; then
    started_workspace_container=1
  fi
fi

while true; do
  if ! opencode_wait_for_running_container "$launch_container_name"; then
    if [[ "$reuse_existing" == '1' && "$recreated_exact_match_container" != '1' ]]; then
      podman rm -f "$container_name" >/dev/null 2>&1 || true
      create_workspace_container "$container_name"
      reuse_existing=0
      recreated_exact_match_container=1
      continue
    fi

    printf 'OpenCode container failed to stay running: %s\n' "$launch_container_name" >&2
    opencode_print_container_startup_diagnostics "$launch_container_name"
    exit 1
  fi

  if [[ "$rename_after_start" == '1' ]]; then
    podman rm -f "$container_name" >/dev/null 2>&1 || true
    podman rename "$launch_container_name" "$container_name" >/dev/null
    launch_container_name="$container_name"
    rename_after_start=0
    old_containers="$(printf '%s\n%s\n' "$old_containers" "$launch_container_name" | sed '/^$/d')"
  fi

  if [[ "$reuse_existing" != '1' ]]; then
    while IFS= read -r old_container; do
      [[ -n "$old_container" ]] || continue
      [[ "$old_container" == "$launch_container_name" ]] && continue
      podman rm -f "$old_container" >/dev/null 2>&1 || true
    done <<< "$old_containers"
  fi

  if ! opencode_wait_for_stable_running_container "$launch_container_name"; then
    if [[ "$reuse_existing" == '1' && "$recreated_exact_match_container" != '1' ]]; then
      podman rm -f "$container_name" >/dev/null 2>&1 || true
      create_workspace_container "$container_name"
      reuse_existing=0
      recreated_exact_match_container=1
      continue
    fi

    printf 'OpenCode container stopped before attach: %s\n' "$launch_container_name" >&2
    opencode_print_container_startup_diagnostics "$launch_container_name"
    exit 1
  fi

  break
done

# This waits for the published host URL before best-effort host browser launch.
if [[ "$publish_external" == '1' && ( "$created_workspace_container" == '1' || "$started_workspace_container" == '1' ) ]]; then
  printf 'Published OpenCode server: %s\n' "$published_url" >&2
  printf 'Host port: %s\n' "$published_port" >&2
  if opencode_wait_for_published_url "$published_url"; then
    opencode_open_published_url_detached "$published_url"
  fi
fi

opencode_exec_podman_interactive_command exec "$container_name" "$OPENCODE_DEFAULT_COMMAND" attach http://127.0.0.1:4096
