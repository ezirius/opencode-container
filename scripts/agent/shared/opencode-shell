#!/usr/bin/env bash

set -euo pipefail

# This script opens nu by default, or runs a command inside a running workspace container.

# This finds the repo root so the script can reach shared helpers.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

# This loads the saved workspace list before the script picks or validates a workspace.
opencode_load_workspaces

if [[ $# -ge 1 ]]; then
  workspace="$1"
  opencode_validate_workspace_name "$workspace"
  opencode_workspace_offset "$workspace" >/dev/null
  shift
else
  workspace="$(opencode_pick_workspace)"
fi

project_name=''

if [[ $# -ge 1 && "$1" == '--' ]]; then
  shift
elif [[ $# -ge 2 ]]; then
  opencode_require_project_name "$1"
  project_name="$1"
  shift
elif [[ $# -eq 1 ]]; then
  opencode_require_project_name "$1"
  project_name="$1"
  shift
fi

if [[ $# -eq 0 ]]; then
  command=("$OPENCODE_SHELL_COMMAND")
else
  command=("$@")
fi

if [[ -n "$project_name" ]]; then
  container_name="$(opencode_running_container "$workspace" "$project_name")"
else
  container_name="$(opencode_running_containers "$workspace")"
  if [[ "$container_name" == *$'\n'* ]]; then
    fail "Multiple running OpenCode containers found for $workspace. Pass a project name."
  fi
fi

[[ -n "$container_name" ]] || fail "No running OpenCode container found for $workspace. Run scripts/agent/shared/opencode-run first."

opencode_exec_podman_interactive_command exec "$container_name" "${command[@]}"
