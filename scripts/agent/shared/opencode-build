#!/usr/bin/env bash

set -euo pipefail

# This script builds a fresh OpenCode image from the saved repo settings.

# This finds the repo root so the script can reach shared helpers and config.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT/lib/shell/shared/common.sh"

if [[ $# -ne 0 ]]; then
  printf 'This script takes no arguments.\n' >&2
  exit 1
fi

# This stops the build unless the checkout satisfies the branch policy for image changes.
opencode_require_build_ready_checkout "$ROOT"

# This builds a timestamped temporary tag before renaming it with the full image id.
timestamp="$(/bin/date +"%Y%m%d-%H%M%S")"
temporary_image_name="$OPENCODE_IMAGE_BASENAME-$OPENCODE_VERSION-$timestamp-$$"

# This removes the temporary image tag after success and on post-build failures.
cleanup_temporary_image() {
  podman rmi "$temporary_image_name" >/dev/null 2>&1 || true
}

trap cleanup_temporary_image EXIT

podman build \
  -f "$ROOT/config/containers/shared/Containerfile" \
  -t "$temporary_image_name" \
  "$ROOT"

# This resolves the built image id and folds its 12-character prefix into the final local image name.
image_id="$(podman image inspect --format '{{.Id}}' "$temporary_image_name")"
image_short_id="${image_id#sha256:}"
image_short_id="${image_short_id:0:12}"
image_name="$OPENCODE_IMAGE_BASENAME-$OPENCODE_VERSION-$timestamp-$image_short_id"
podman tag "$temporary_image_name" "$image_name"
trap - EXIT
cleanup_temporary_image

printf 'Built image: %s\n' "$image_name"
